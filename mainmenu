# ================================================================
#  BLUEPRINT TOOLS MENU  (hub-style — matches image exactly)
# ================================================================
blueprint_tools_menu() {
    while true; do
        hub_header "Minimal  •  Clean  •  High Performance"
        echo -e "  ${WH}${BD}SELECT AN OPTION:${N}"; echo ""
        echo -e "  ${BCY}[ 1 ]${N}  ${BGN}🚀${N}  Install Blueprint 1"
        echo -e "  ${BCY}[ 2 ]${N}  ${BYE}⚡${N}  Install Blueprint 2  ${DIM}(Fresh Rebuild)${N}"
