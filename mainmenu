                if [ -f "$PT_DIR/nebula.blueprint" ] && [ -f "$PT_DIR/blueprint.sh" ]; then
                    bash "$PT_DIR/blueprint.sh" -install nebula
                    ok "Nebula installed."
                else
                    err "Download failed or Blueprint not installed."
                    pause; continue
                fi

                step "[3/4]" "Rebuilding panel assets..."
                (cd "$PT_DIR" && yarn build --silent 2>/dev/null) &
                spinner "Assets rebuild"

                step "[4/4]" "Clearing cache..."
                (cd "$PT_DIR" && php artisan view:clear && php artisan config:clear) &
                spinner "Cache clear"

                echo ""; div
                echo -e "  ${BGN}${BD}🎉  Nebula installed successfully!${N}"; div
                pause ;;

            # ── 2) Euphoria ───────────────────────────────────
            2)
                clear; echo ""
                echo -e "${MG}  ══════════════════════════════════════════════════════${N}"
                echo -e "              ${BYE}${BD}EUPHORIA — AUTO INSTALL${N}"
                echo -e "${MG}  ══════════════════════════════════════════════════════${N}"
                echo ""

                require_root || continue
                require_ptero || continue

                info "Installing Euphoria theme via Blueprint..."
                echo ""

                step "[1/4]" "Downloading Euphoria theme..."
                (
                    cd "$PT_DIR" || exit 1
                    EUPHORIA_URL="https://github.com/BlueprintFramework/themes/releases/latest/download/euphoria.blueprint"
                    if curl -fsSL "$EUPHORIA_URL" -o euphoria.blueprint 2>/dev/null; then
                        :
                    else
                        EUPHORIA_URL=$(curl -s https://api.github.com/repos/BlueprintFramework/themes/releases/latest \
                            | grep '"browser_download_url"' | grep -i 'euphoria' | head -1 | cut -d'"' -f4)
                        [ -n "$EUPHORIA_URL" ] && curl -fsSL "$EUPHORIA_URL" -o euphoria.blueprint 2>/dev/null
                    fi
                    [ ! -f "euphoria.blueprint" ] && exit 1
                    true
                ) &
                spinner "Downloading Euphoria"

                step "[2/4]" "Installing Euphoria extension..."
                if [ -f "$PT_DIR/euphoria.blueprint" ] && [ -f "$PT_DIR/blueprint.sh" ]; then
                    bash "$PT_DIR/blueprint.sh" -install euphoria
                    ok "Euphoria installed."
                else
                    err "Download failed or Blueprint not installed."
                    pause; continue
                fi

                step "[3/4]" "Rebuilding panel assets..."
                (cd "$PT_DIR" && yarn build --silent 2>/dev/null) &
                spinner "Assets rebuild"

                step "[4/4]" "Clearing cache..."
                (cd "$PT_DIR" && php artisan view:clear && php artisan config:clear) &
                spinner "Cache clear"

                echo ""; div
                echo -e "  ${BGN}${BD}🎉  Euphoria installed successfully!${N}"; div
                pause ;;

            # ── 3) Uninstall ──────────────────────────────────
            3)
                clear; echo ""
                echo -e "${MG}  ══════════════════════════════════════════════════════${N}"
                echo -e "              ${BYE}${BD}UNINSTALL THEME${N}"
                echo -e "${MG}  ══════════════════════════════════════════════════════${N}"
                echo ""

                require_root || continue
                require_ptero || continue

                if [ ! -f "$PT_DIR/blueprint.sh" ]; then
                    err "Blueprint is not installed at $PT_DIR"
                    pause; continue
                fi

                echo -e "  ${BCY}Installed extensions:${N}"
                echo ""
                bash "$PT_DIR/blueprint.sh" -list 2>/dev/null \
                    || ls "$PT_DIR/.blueprint/extensions/" 2>/dev/null \
                    || info "No extensions found."
                echo ""
                echo -ne "  ${BYE}  Extension name to remove: ${N}"; read -r ext_name
                if [ -z "$ext_name" ]; then info "No name entered. Cancelled."; pause; continue; fi

                echo ""
                step "[1/3]" "Removing extension '$ext_name'..."
                bash "$PT_DIR/blueprint.sh" -remove "$ext_name"
                ok "Extension '$ext_name' removed."

                step "[2/3]" "Rebuilding panel assets..."
                (cd "$PT_DIR" && yarn build --silent 2>/dev/null) &
                spinner "Assets rebuild"

                step "[3/3]" "Clearing cache..."
                (cd "$PT_DIR" && php artisan view:clear && php artisan config:clear) &
                spinner "Cache clear"

                echo ""; div
                echo -e "  ${BGN}${BD}✔  Uninstall complete.${N}"; div
                pause ;;

            # ── 4) Add Tool ───────────────────────────────────
            4)
                clear; echo ""
                echo -e "${MG}  ══════════════════════════════════════════════════════${N}"
                echo -e "              ${BYE}${BD}ADD TOOL — AUTO INSTALL${N}"
                echo -e "${MG}  ══════════════════════════════════════════════════════${N}"
                echo ""

                require_root || continue
                require_ptero || continue

                if [ ! -f "$PT_DIR/blueprint.sh" ]; then
                    err "Blueprint is not installed at $PT_DIR"
                    pause; continue
                fi

                echo -e "  ${BCY}Provide a .blueprint extension file to install:${N}"
                echo ""
                echo -ne "  ${BYE}  Path to .blueprint file: ${N}"; read -r tool_path
                if [ ! -f "$tool_path" ]; then
                    err "File not found: $tool_path"; pause; continue
                fi

                fname=$(basename "$tool_path")
                ext_name="${fname%.blueprint}"

                step "[1/3]" "Copying $fname to $PT_DIR..."
                cp "$tool_path" "$PT_DIR/"
                ok "File copied."

                step "[2/3]" "Installing extension '$ext_name'..."
                bash "$PT_DIR/blueprint.sh" -install "$ext_name"
                ok "Extension installed."

                step "[3/3]" "Clearing cache & rebuilding assets..."
                (cd "$PT_DIR"
                 yarn build --silent 2>/dev/null
                 php artisan view:clear && php artisan config:clear) &
                spinner "Cache + assets"

                echo ""; div
                echo -e "  ${BGN}${BD}🎉  Tool '$ext_name' installed successfully!${N}"; div
                pause ;;

            # ── 0) Back ───────────────────────────────────────
            0) break ;;

            *) err "Invalid option — choose 0–4."; sleep 1 ;;
        esac
    done
}

# ================================================================
#  MAIN LOOP
# ================================================================
while true; do
    main_menu
    read -r main_opt
    case "$main_opt" in
        1) blueprint_tools_menu ;;
        2) theme_manager_menu ;;
        3)
            clear; echo ""
            echo -e "  ${BCY}${BD}  ✦  Goodbye! — Blueprint Control Panel${N}"; echo ""
            exit 0 ;;
        *)
            err "Invalid option — choose 1, 2 or 3."; sleep 1 ;;
    esac
done
