            # ── 1) Nebula ─────────────────────────────────────
            1)
                clear; echo ""
                echo -e "${MG}  ══════════════════════════════════════════════════════${N}"
                echo -e "              ${BYE}${BD}NEBULA — AUTO INSTALL${N}"
                echo -e "${MG}  ══════════════════════════════════════════════════════${N}"
                echo ""

                require_root || continue
                require_ptero || continue

                info "Installing Nebula theme via Blueprint..."
                echo ""

                step "[1/4]" "Downloading Nebula theme..."
                (
                    cd "$PT_DIR" || exit 1
                    NEBULA_URL="https://github.com/BlueprintFramework/themes/releases/latest/download/nebula.blueprint"
                    if curl -fsSL "$NEBULA_URL" -o nebula.blueprint 2>/dev/null; then
                        :
                    else
                        # fallback: search GitHub releases
                        NEBULA_URL=$(curl -s https://api.github.com/repos/BlueprintFramework/themes/releases/latest \
