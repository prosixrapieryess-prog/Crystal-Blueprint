#!/bin/bash
# ================================================================
#  BLUEPRINT CONTROL PANEL  —  ProXLegendYT
#  Full rewrite — clean, functional, hub-style UI
# ================================================================

# ── Colors ───────────────────────────────────────────────────────
RE='\033[0;31m';   GR='\033[0;32m';   YE='\033[1;33m'
CY='\033[0;36m';   MG='\033[0;35m';   WH='\033[1;37m'
BCY='\033[1;36m';  BGN='\033[1;32m';  BYE='\033[1;33m'
BRE='\033[1;31m';  BBL='\033[1;34m';  DGR='\033[1;30m'
DIM='\033[2m';     BD='\033[1m';      N='\033[0m'

PT_DIR="/var/www/pterodactyl"

# ================================================================
#  HELPERS
# ================================================================
div()  { echo -e "  ${BCY}────────────────────────────────────────────────────────${N}"; }
hdiv() { echo -e "  ${DGR}────────────────────────────────────────────────────────${N}"; }

pause() {
    echo ""; hdiv
    echo -ne "  ${DIM}Press ${BCY}Enter${N}${DIM} to continue...${N}"; read -r
}

ok()   { echo -e "  ${BGN}  ✔  ${GR}$*${N}"; }
err()  { echo -e "  ${BRE}  ✘  ${RE}$*${N}"; }
info() { echo -e "  ${BCY}  •  ${CY}$*${N}"; }
step() { echo -e "\n  ${BCY}${BD}$1${N}  ${WH}$2${N}"; }

typewriter() {
    local text="$1" color="${2:-$WH}"
    echo -ne "  ${color}"
    for ((i=0; i<${#text}; i++)); do
        printf '%s' "${text:$i:1}"; sleep 0.025
    done
    echo -e "${N}"
}

spinner() {
    local label="$1" pid=$! i=0
    local frames=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
    while kill -0 "$pid" 2>/dev/null; do
        printf "  ${BCY}%s${N}  ${WH}%-38s${N}\r" "${frames[$i]}" "$label..."
        i=$(( (i+1) % 10 )); sleep 0.08
    done
    wait "$pid"; local rc=$?
    if [ $rc -eq 0 ]; then printf "  ${BGN}✔${N}  ${WH}%-40s${BGN} done${N}\n" "$label"
    else               printf "  ${BRE}✘${N}  ${WH}%-40s${BRE} failed${N}\n" "$label"; fi
    return $rc
}

require_root() {
    if [ "$EUID" -ne 0 ]; then
        err "This module must be run as root (sudo)."; pause; return 1
    fi
}

require_ptero() {
    if [ ! -d "$PT_DIR" ]; then
        err "Pterodactyl not found at ${CY}$PT_DIR${RE}."
        info "Install Pterodactyl first, then re-run this option."
        pause; return 1
    fi
}

# ================================================================
#  HUB HEADER  (used by Blueprint Tools + hyperv1 submenus)
# ================================================================
hub_header() {
    local subtitle="${1:-Minimal  •  Clean  •  High Performance}"
    clear; echo ""
    echo -e "  ${BCY}┌──────────────────────────────────────────────────────┐  ║${N}"
    echo -e "  ${BCY}│${N}                                                      ${BCY}│  ║${N}"
    echo -e "  ${BCY}│${N}        ${BYE}${BD}⚡  BLUEPRINT CONTROL HUB  ⚡${N}                ${BCY}│  ║${N}"
    echo -e "  ${BCY}│${N}                                                      ${BCY}│  ║${N}"
    echo -e "  ${BCY}│${N}        ${BCY}${subtitle}${N}"
    echo -e "  ${BCY}│${N}                                                      ${BCY}│${N}"
    echo -e "  ${BCY}└──────────────────────────────────────────────────────┘${N}"
    echo ""
    local datenow user_now host_now
    datenow=$(date '+%H:%M')
    user_now=$(whoami 2>/dev/null || echo "user")
    host_now=$(hostname  2>/dev/null || echo "-")
    echo -e "  ${BYE}User:${N} ${WH}${user_now}${N}   ${BYE}Host:${N} ${WH}${host_now}${N}   ${BYE}Date:${N} ${WH}${datenow}${N}"
    div; echo ""
}

