# ================================================================
#  MODULE 1 — INSTALL BLUEPRINT 1
# ================================================================
install_blueprint_1() {
    clear; echo ""
    echo -e "  ${BCY}╔══════════════════════════════════════════════════════╗${N}"
    echo -e "  ${BCY}║${N}  ${BYE}${BD}⚡ Blueprint Control Hub${N}  ${DGR}::${N}  ${BGN}Install Blueprint 1${N}  ${BCY}║${N}"
    echo -e "  ${BCY}╚══════════════════════════════════════════════════════╝${N}"
    echo ""
    require_root || return
    require_ptero || return

    info "Target: $PT_DIR"
    typewriter "  ⏳  Starting in 3 seconds..." "$WH"; sleep 3

    step "[1/7]" "Checking environment..."
    ok "Pterodactyl found at $PT_DIR"

    step "[2/7]" "Installing system dependencies..."
    (export DEBIAN_FRONTEND=noninteractive
     apt-get update -y -q 2>/dev/null
     apt-get install -y -q curl wget unzip ca-certificates git gnupg zip 2>/dev/null) &
    spinner "System packages"

    step "[3/7]" "Setting up Node.js 20 + Yarn..."
    (mkdir -p /etc/apt/keyrings
     curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
         | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg 2>/dev/null
     echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" \
         > /etc/apt/sources.list.d/nodesource.list
     export DEBIAN_FRONTEND=noninteractive
     apt-get update -y -q 2>/dev/null
     apt-get install -y -q nodejs 2>/dev/null
     npm install -g yarn -q 2>/dev/null) &
    spinner "Node.js 20 + Yarn"

    step "[4/7]" "Downloading Blueprint (latest release)..."
    (cd "$PT_DIR" || exit 1
     DL=$(curl -s https://api.github.com/repos/BlueprintFramework/framework/releases/latest \
         | grep '"browser_download_url"' | grep 'release\.zip' | head -1 | cut -d'"' -f4)
     [ -z "$DL" ] && exit 1
     wget -q "$DL" -O release.zip
     unzip -o -q release.zip
     rm -f release.zip) &
    spinner "Download & extract"

    step "[5/7]" "Writing .blueprintrc config..."
    printf 'WEBUSER="www-data";\nOWNERSHIP="www-data:www-data";\nUSERSHELL="/bin/bash";\n' \
        > "$PT_DIR/.blueprintrc"
    chmod +x "$PT_DIR/blueprint.sh" 2>/dev/null
    ok "Config written."

    step "[6/7]" "Running Blueprint installer..."
    bash "$PT_DIR/blueprint.sh"

    step "[7/7]" "Fixing permissions & clearing cache..."
    (chown -R www-data:www-data "$PT_DIR" 2>/dev/null
     find "$PT_DIR" -type d -exec chmod 755 {} \; 2>/dev/null
     find "$PT_DIR" -type f -exec chmod 644 {} \; 2>/dev/null
     chmod +x "$PT_DIR/artisan" "$PT_DIR/blueprint.sh" 2>/dev/null
     yarn --cwd "$PT_DIR" install --production --silent 2>/dev/null
     cd "$PT_DIR" && php artisan view:clear && php artisan config:clear && php artisan route:clear) &
    spinner "Permissions + cache"

    echo ""; div
    echo -e "  ${BGN}${BD}🎉  Blueprint 1 installed successfully!${N}"; div
    pause
}

# ================================================================
#  MODULE 2 — INSTALL BLUEPRINT 2  (Fresh Rebuild)
# ================================================================
install_blueprint_2() {
    clear; echo ""
    echo -e "  ${BCY}╔══════════════════════════════════════════════════════╗${N}"
    echo -e "  ${BCY}║${N}  ${BYE}${BD}⚡ Blueprint Control Hub${N}  ${DGR}::${N}  ${BYE}Fresh Rebuild${N}        ${BCY}║${N}"
    echo -e "  ${BCY}╚══════════════════════════════════════════════════════╝${N}"
    echo ""
    require_root || return
    require_ptero || return

    echo -e "  ${BRE}⚠️   WARNING: This will WIPE Blueprint and do a full clean reinstall.${N}"
    echo -ne "  ${BYE}  Type ${WH}YES${BYE} to confirm: ${N}"; read -r confirm
    if [ "$confirm" != "YES" ]; then info "Cancelled."; pause; return; fi

    typewriter "  ⏳  Fresh rebuild starting in 3 seconds..." "$WH"; sleep 3

    step "[1/8]" "Removing old Blueprint files..."
    (rm -f  "$PT_DIR/release.zip"
     rm -f  "$PT_DIR/.blueprintrc"
     rm -f  "$PT_DIR/blueprint.sh"
     rm -rf "$PT_DIR/.blueprint") &
    spinner "Purging old data"

    step "[2/8]" "Clearing artisan cache..."
    (cd "$PT_DIR" || exit 1
     php artisan view:clear   2>/dev/null
     php artisan config:clear 2>/dev/null
     php artisan route:clear  2>/dev/null
     php artisan cache:clear  2>/dev/null) &
    spinner "Artisan cache"

    step "[3/8]" "Reinstalling system packages..."
    (export DEBIAN_FRONTEND=noninteractive
     apt-get update -y -q 2>/dev/null
     apt-get install -y -q curl wget unzip ca-certificates git gnupg zip 2>/dev/null) &
    spinner "System packages"

    step "[4/8]" "Reinstalling Node.js 20 + Yarn..."
    (mkdir -p /etc/apt/keyrings
     curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
         | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg 2>/dev/null
     echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" \
         > /etc/apt/sources.list.d/nodesource.list
     export DEBIAN_FRONTEND=noninteractive
     apt-get update -y -q 2>/dev/null
     apt-get install -y -q nodejs 2>/dev/null
     npm install -g yarn -q 2>/dev/null) &
    spinner "Node.js 20 + Yarn"

    step "[5/8]" "Downloading fresh Blueprint release..."
    (cd "$PT_DIR" || exit 1
     DL=$(curl -s https://api.github.com/repos/BlueprintFramework/framework/releases/latest \
         | grep '"browser_download_url"' | grep 'release\.zip' | head -1 | cut -d'"' -f4)
     [ -z "$DL" ] && exit 1
     wget -q "$DL" -O release.zip
     unzip -o -q release.zip
     rm -f release.zip) &
    spinner "Download & extract"

    step "[6/8]" "Writing fresh .blueprintrc config..."
    printf 'WEBUSER="www-data";\nOWNERSHIP="www-data:www-data";\nUSERSHELL="/bin/bash";\n' \
        > "$PT_DIR/.blueprintrc"
    chmod +x "$PT_DIR/blueprint.sh" 2>/dev/null
    ok "Config written."

    step "[7/8]" "Running Blueprint installer..."
    bash "$PT_DIR/blueprint.sh"

    step "[8/8]" "Rebuilding assets & fixing permissions..."
    (chown -R www-data:www-data "$PT_DIR" 2>/dev/null
     find "$PT_DIR" -type d -exec chmod 755 {} \; 2>/dev/null
     find "$PT_DIR" -type f -exec chmod 644 {} \; 2>/dev/null
     chmod +x "$PT_DIR/artisan" "$PT_DIR/blueprint.sh" 2>/dev/null
     yarn --cwd "$PT_DIR" install --production --silent 2>/dev/null
     cd "$PT_DIR" && yarn build --silent 2>/dev/null
     php artisan view:clear && php artisan config:clear && php artisan route:clear) &
    spinner "Assets + permissions"

    echo ""; div
    echo -e "  ${BGN}${BD}🎉  Blueprint 2 (Fresh Rebuild) complete!${N}"; div
    pause
}

# ================================================================
#  MODULE 3 — AUTO FIX / REPAIR
# ================================================================
auto_fix_repair() {
    clear; echo ""
    echo -e "  ${BCY}╔══════════════════════════════════════════════════════╗${N}"
    echo -e "  ${BCY}║${N}  ${BYE}${BD}⚡ Blueprint Control Hub${N}  ${DGR}::${N}  ${BCY}Auto Fix / Repair${N}    ${BCY}║${N}"
    echo -e "  ${BCY}╚══════════════════════════════════════════════════════╝${N}"
    echo ""
    require_root || return
    require_ptero || return

    info "Running: Permissions → Cache → Composer → Migrations"; echo ""

    step "[1/4]" "Repairing file permissions..."
    (chown -R www-data:www-data "$PT_DIR" 2>/dev/null
     find "$PT_DIR" -type d -exec chmod 755 {} \; 2>/dev/null
     find "$PT_DIR" -type f -exec chmod 644 {} \; 2>/dev/null
     chmod +x "$PT_DIR/artisan" "$PT_DIR/blueprint.sh" 2>/dev/null) &
    spinner "File permissions"

    step "[2/4]" "Clearing all artisan caches..."
    (cd "$PT_DIR" || exit 1
     php artisan view:clear    2>/dev/null
     php artisan config:clear  2>/dev/null
     php artisan route:clear   2>/dev/null
     php artisan cache:clear   2>/dev/null
     php artisan queue:restart 2>/dev/null) &
    spinner "Artisan cache + queue"

    step "[3/4]" "Running Composer install..."
    (cd "$PT_DIR" || exit 1
     composer install --no-dev --optimize-autoloader -q 2>/dev/null) &
    spinner "Composer dependencies"

    step "[4/4]" "Running database migrations..."
    (cd "$PT_DIR" || exit 1
     php artisan migrate --force -q 2>/dev/null) &
    spinner "Database migrations"

    echo ""; div
    echo -e "  ${BGN}${BD}✔  Auto Fix / Repair complete!${N}"; div
    pause
}

# ================================================================
#  MODULE 4 — HYPERV1
# ================================================================
hyperv1_menu() {
    while true; do
        hub_header "hyperv1 Tools"
        echo -e "  ${WH}${BD}SELECT AN OPTION:${N}"; echo ""
        echo -e "  ${BCY}[ 1 ]${N}  ${BGN}📋${N}  List Installed Extensions"
        echo -e "  ${BCY}[ 2 ]${N}  ${BYE}📦${N}  Install Extension  ${DIM}(.blueprint file)${N}"
        echo -e "  ${BCY}[ 3 ]${N}  ${BRE}🗑️ ${N}  Remove Extension"
        echo -e "  ${BCY}[ 4 ]${N}  ${BBL}🔨${N}  Rebuild Panel Assets"
        echo -e "  ${BCY}[ 5 ]${N}  ${BCY}📊${N}  Blueprint Status Check"
        echo ""
        echo -e "  ${BRE}[ 0 ]${N}  ${RE}✗${N}  Back"
        echo ""; div; echo ""
        echo -ne "  ${BYE}${BD}👉 Enter your choice: ${N}"
        read -r hv_opt

        case "$hv_opt" in

            1)  # List extensions ─────────────────────────────
                clear; echo -e "\n  ${BCY}${BD}📋  INSTALLED EXTENSIONS${N}"; div; echo ""
                if [ -f "$PT_DIR/blueprint.sh" ]; then
                    bash "$PT_DIR/blueprint.sh" -list 2>/dev/null \
                    || ls "$PT_DIR/.blueprint/extensions/" 2>/dev/null \
                    || info "No extensions found."
                else err "Blueprint is not installed at $PT_DIR"; fi
                pause ;;

            2)  # Install extension ───────────────────────────
                clear; echo -e "\n  ${BCY}${BD}📦  INSTALL EXTENSION${N}"; div; echo ""
                echo -ne "  ${BYE}  Path to .blueprint file: ${N}"; read -r ext_path
                if [ ! -f "$ext_path" ]; then err "File not found: $ext_path"; pause; continue; fi
                if [ ! -f "$PT_DIR/blueprint.sh" ]; then err "Blueprint is not installed."; pause; continue; fi
                fname=$(basename "$ext_path")
                cp "$ext_path" "$PT_DIR/"
                info "Installing: ${fname%.blueprint}"
                bash "$PT_DIR/blueprint.sh" -install "${fname%.blueprint}"
                ok "Extension installed."; pause ;;

            3)  # Remove extension ────────────────────────────
                clear; echo -e "\n  ${BCY}${BD}🗑️   REMOVE EXTENSION${N}"; div; echo ""
                echo -ne "  ${BYE}  Extension name: ${N}"; read -r ext_name
                if [ -z "$ext_name" ]; then info "No name entered."; pause; continue; fi
                if [ ! -f "$PT_DIR/blueprint.sh" ]; then err "Blueprint not installed."; pause; continue; fi
                bash "$PT_DIR/blueprint.sh" -remove "$ext_name"
                ok "Extension '$ext_name' removed."; pause ;;

            4)  # Rebuild assets ───────────────────────────────
                clear; echo -e "\n  ${BCY}${BD}🔨  REBUILD PANEL ASSETS${N}"; div; echo ""
                if [ ! -d "$PT_DIR" ]; then err "Pterodactyl not found."; pause; continue; fi
                (cd "$PT_DIR" && yarn build 2>/dev/null) &
                spinner "Building panel assets"
                ok "Assets rebuilt."; pause ;;

            5)  # Status check ─────────────────────────────────
                clear; echo -e "\n  ${BCY}${BD}📊  BLUEPRINT STATUS CHECK${N}"; div; echo ""

                printf "  ${WH}%-24s${N}" "Pterodactyl dir:"
                [ -d "$PT_DIR" ] && ok "Found at $PT_DIR" || err "Missing — $PT_DIR not found"

                printf "  ${WH}%-24s${N}" "blueprint.sh:"
                [ -f "$PT_DIR/blueprint.sh" ] && ok "Present" || err "Missing"

                printf "  ${WH}%-24s${N}" ".blueprintrc:"
                [ -f "$PT_DIR/.blueprintrc" ] && ok "Present" || err "Missing"

                printf "  ${WH}%-24s${N}" "Node.js:"
                node_ver=$(node -v 2>/dev/null)
                [ -n "$node_ver" ] && ok "$node_ver" || err "Not installed"

                printf "  ${WH}%-24s${N}" "Yarn:"
                yarn_ver=$(yarn -v 2>/dev/null)
                [ -n "$yarn_ver" ] && ok "v$yarn_ver" || err "Not installed"

                printf "  ${WH}%-24s${N}" "PHP:"
                php_ver=$(php -r 'echo PHP_VERSION;' 2>/dev/null)
                [ -n "$php_ver" ] && ok "$php_ver" || err "Not installed"

                printf "  ${WH}%-24s${N}" "Composer:"
                comp_ver=$(composer --version 2>/dev/null | awk '{print $3}')
                [ -n "$comp_ver" ] && ok "$comp_ver" || err "Not installed"

                printf "  ${WH}%-24s${N}" "Web server:"
                if systemctl is-active --quiet nginx 2>/dev/null; then ok "nginx — active"
                elif systemctl is-active --quiet apache2 2>/dev/null; then ok "apache2 — active"
                else err "Neither nginx nor apache2 is running"; fi

                pause ;;

            0) break ;;
            *) err "Invalid option."; sleep 1 ;;
        esac
    done
}

# ================================================================
#  THEME MANAGER  (styled to match reference image)
# ================================================================
theme_manager_menu() {

    # ── helper: draw the Theme Manager main menu ──────────────
